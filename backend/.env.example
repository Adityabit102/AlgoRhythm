# Mock mode: serve deterministic predictions without a trained model (default on)
USE_MOCK_MODEL=1

# App
ENVIRONMENT=development
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000
RATE_LIMIT_PER_MINUTE=30

# Spotify (needed only when USE_MOCK_MODEL=0)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# AWS / S3 (needed only when USE_MOCK_MODEL=0; prod uses IAM instance role)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=algorhythm-artifacts
S3_ARTIFACT_PREFIX=artifacts/latest
